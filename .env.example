# ParserNews local Docker environment example.
# Copy to .env for local overrides. Do not commit .env.

# Basic Auth for dashboard/API.
PARSERNEWS_AUTH_ENABLED=true
APP_ADMIN_USERNAME=
APP_ADMIN_PASSWORD=

# Docker PostgreSQL local credentials.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# SEC watchlist scanner is disabled by default.
# You can also manage the watchlist from the dashboard without restarting Docker.
SEC_SCANNER_ENABLED=false
SEC_SCANNER_WATCHLIST=
SEC_SCANNER_MAX_FILINGS_PER_CIK=20

# Manual Telegram send is disabled by default.
# Keep token/chat id secret and never commit real values.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Automatic alert dispatch is disabled by default.
ALERTS_DISPATCH_ENABLED=false

# Optional scheduled Full Refresh is disabled by default.
# Manual Full Refresh from the dashboard works without enabling this.
FULL_REFRESH_SCHEDULER_ENABLED=false
FULL_REFRESH_SCHEDULER_INITIAL_DELAY_MS=120000
FULL_REFRESH_SCHEDULER_FIXED_DELAY_MS=900000

# Optional manual OpenAI AI Review for Deal Groups.
# Disabled by default. Never commit a real API key.
OPENAI_ANALYSIS_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ANALYSIS_MAX_INPUT_CHARS=12000
