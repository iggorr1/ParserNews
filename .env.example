# ParserNews local Docker environment example.
# Copy to .env for local overrides. Do not commit .env with real values.

# ─── Auth ────────────────────────────────────────────────────────────────────
# Basic auth for dashboard and API. Change the password before exposing publicly.
PARSERNEWS_AUTH_ENABLED=true
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=parsernews
POSTGRES_USER=parsernews
POSTGRES_PASSWORD=parsernews

# ─── RSS Monitoring ───────────────────────────────────────────────────────────
# Full Refresh runs all 25 RSS sources on a schedule.
# Recommended: enable both for continuous monitoring.
FULL_REFRESH_SCHEDULER_ENABLED=true
FULL_REFRESH_SCHEDULER_INITIAL_DELAY_MS=60000
# Every 15 minutes.
FULL_REFRESH_SCHEDULER_FIXED_DELAY_MS=900000

# ─── SEC Watchlist Scanner ────────────────────────────────────────────────────
# Polls known companies by CIK. Confirmation layer — not discovery.
# Manage the watchlist from the dashboard; no restart needed.
SEC_SCANNER_ENABLED=false
SEC_SCANNER_WATCHLIST=
SEC_SCANNER_MAX_FILINGS_PER_CIK=20

# ─── SEC Discovery Scanner ────────────────────────────────────────────────────
# Broader discovery via EDGAR current-filings Atom feeds by form type.
# This is the main early-signal layer — enable for production use.
#
# Recommended production settings:
#   SEC_DISCOVERY_ENABLED=true
#   SEC_DISCOVERY_SCHEDULER_ENABLED=true
#   SEC_DISCOVERY_SCHEDULER_FIXED_DELAY_MS=300000  (every 5 minutes)
#
# Forms include base forms and their /A amendment variants.
# SC TO-T/A and SC TO-I/A are processed automatically when base form is configured.
# Increase SEC_DISCOVERY_MAX_FILINGS_PER_RUN if you want deeper history per run.
# Keep SEC_DISCOVERY_REQUEST_DELAY_MS >= 200 to respect EDGAR fair-access policy.
SEC_DISCOVERY_ENABLED=false
SEC_DISCOVERY_MAX_FILINGS_PER_RUN=100
SEC_DISCOVERY_FORMS=8-K,SC TO-T,SC TO-T/A,SC TO-I,SC TO-I/A,SC 14D9,DEFM14A,PREM14A,425,S-4
SEC_DISCOVERY_FETCH_PRIMARY_DOCUMENT=false
SEC_DISCOVERY_REQUEST_DELAY_MS=200
SEC_DISCOVERY_SCHEDULER_ENABLED=false
SEC_DISCOVERY_SCHEDULER_INITIAL_DELAY_MS=60000
# Every 5 minutes.
SEC_DISCOVERY_SCHEDULER_FIXED_DELAY_MS=300000

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Manual preview and send only — no auto-trading, no auto-dispatch.
# Keep token and chat-id out of version control.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Alert Dispatch ───────────────────────────────────────────────────────────
# Automatic periodic dispatch of alert-eligible signals via Telegram.
# Requires TELEGRAM_ENABLED=true and valid token/chat-id.
# Keep false until you have verified signal quality via manual review.
ALERTS_DISPATCH_ENABLED=false

# ─── OpenAI AI Review ─────────────────────────────────────────────────────────
# Manual-only AI review for Deal Groups. Never used in automatic alert path.
# Requires a valid OpenAI API key (never commit a real key).
OPENAI_ANALYSIS_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ANALYSIS_MAX_INPUT_CHARS=12000
